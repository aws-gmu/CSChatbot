"""
AWS Lambda function that scrapes the GMU School of Computing catalog
and writes structured .txt files to S3 for use as an LLM knowledge base.

Triggered on a schedule via EventBridge (e.g., weekly).
"""
import os
import re
import logging
import boto3
import requests
from bs4 import BeautifulSoup

logger = logging.getLogger()
logger.setLevel(logging.INFO)

S3_BUCKET = os.environ["S3_BUCKET"]
S3_PREFIX = os.environ.get("S3_PREFIX", "gmu-catalog/")
BASE_URL = "https://catalog.gmu.edu/colleges-schools/engineering-computing/school-computing"

METADATA = (
    "University: George Mason University\n"
    "School: Long Nguyen and Kimmy Duong School of Computing\n"
    "College: College of Engineering and Computing"
)

DEPT_PAGES = [
    (f"{BASE_URL}/computer-science/", "computer-science", "Department of Computer Science"),
    (f"{BASE_URL}/information-sciences-technology/", "ist", "Department of Information Sciences and Technology"),
    (f"{BASE_URL}/statistics/", "statistics", "Department of Statistics"),
]

PROGRAM_PAGES = [
    (f"{BASE_URL}/computer-science/computer-science-bs/", "programs/cs-bs.txt", "Computer Science, BS"),
    (f"{BASE_URL}/computer-science/applied-computer-science-bs/", "programs/applied-cs-bs.txt", "Applied Computer Science, BS"),
    (f"{BASE_URL}/computer-science/computer-science-ms/", "programs/cs-ms.txt", "Computer Science, MS"),
    (f"{BASE_URL}/computer-science/computer-science-phd/", "programs/cs-phd.txt", "Computer Science, PhD"),
    (f"{BASE_URL}/computer-science/software-engineering-ms/", "programs/swe-ms.txt", "Software Engineering, MS"),
    (f"{BASE_URL}/information-sciences-technology/information-technology-bs/", "programs/it-bs.txt", "Information Technology, BS"),
    (f"{BASE_URL}/information-sciences-technology/applied-information-technology-ms/", "programs/ait-ms.txt", "Applied Information Technology, MS"),
    (f"{BASE_URL}/information-sciences-technology/information-systems-ms/", "programs/infs-ms.txt", "Information Systems, MS"),
    (f"{BASE_URL}/statistics/statistics-bs/", "programs/stat-bs.txt", "Statistics, BS"),
    (f"{BASE_URL}/statistics/statistical-science-ms/", "programs/stat-science-ms.txt", "Statistical Science, MS"),
    (f"{BASE_URL}/statistics/biostatistics-ms/", "programs/biostatistics-ms.txt", "Biostatistics, MS"),
    (f"{BASE_URL}/statistics/statistical-science-phd/", "programs/stat-science-phd.txt", "Statistical Science, PhD"),
]

SUBJECT_NAMES = {
    "CS": "Computer Science",
    "SWE": "Software Engineering",
    "ISA": "Information Security and Assurance",
    "COMP": "Computing",
    "IT": "Information Technology",
    "AIT": "Applied Information Technology",
    "INFS": "Information Systems",
    "STAT": "Statistics",
}

s3 = boto3.client("s3")


# ── Helpers ───────────────────────────────────────────────────────

def put_s3(key, content):
    """Write a text file to S3."""
    full_key = f"{S3_PREFIX}{key}"
    s3.put_object(Bucket=S3_BUCKET, Key=full_key, Body=content.encode("utf-8"), ContentType="text/plain")
    logger.info(f"Uploaded s3://{S3_BUCKET}/{full_key}")


def build_file_content(title, source_url, body):
    return f"{title}\n\nSource: {source_url}\n{METADATA}\n\n{body.strip()}\n"


def fetch_soup(url):
    resp = requests.get(url, timeout=15)
    resp.raise_for_status()
    return BeautifulSoup(resp.text, "html.parser")


# ── Extractors ────────────────────────────────────────────────────

def extract_overview(soup):
    text = soup.get_text("\n", strip=True)
    end = text.find("Department Faculty")
    if end == -1:
        end = text.find("Professors\n")
    if end == -1:
        end = min(2000, len(text))
    overview = text[:end].strip()
    for skip in ["Overview", "Faculty", "Programs", "Courses"]:
        overview = overview.replace(f"\n{skip}\n", "\n")
    return overview


def extract_faculty(soup):
    text = soup.get_text("\n", strip=True)
    start = text.find("Department Faculty")
    if start == -1:
        start = text.find("Professors\n")
    if start == -1:
        return ""
    end = text.find("Course Offerings", start)
    if end == -1:
        end = text.find("Level Courses", start)
    if end == -1:
        end = min(start + 3000, len(text))
    section = text[start:end].strip()
    lines = []
    for line in section.split("\n"):
        line = line.strip()
        if not line or line == "Department Faculty":
            continue
        if any(r in line for r in ["Professors", "Instructors", "Adjunct", "Emeritus", "Affiliated"]):
            lines.append(f"\n{line}\n")
        else:
            lines.append(line)
    return "\n".join(lines)


def extract_program(soup):
    main = soup.find("main") or soup.find("div", id="content") or soup.body
    if not main:
        return ""
    for tag in main.find_all(["nav", "script", "style"]):
        tag.decompose()
    return main.get_text("\n", strip=True)


def identify_subjects(soup):
    blocks = soup.find_all("div", class_="courseblock")
    subjects = {}
    for block in blocks:
        code_tag = block.find("strong", class_="cb_code")
        if code_tag:
            code_text = code_tag.get_text(strip=True).rstrip(":")
            parts = code_text.split()
            if len(parts) >= 2:
                subj = parts[0]
                if subj not in subjects:
                    subjects[subj] = []
                subjects[subj].append(block)
    return subjects


def courses_to_text(blocks):
    parts = []
    for block in blocks:
        title_div = block.find("div", class_="courseblocktitle")
        desc_div = block.find("div", class_="courseblockdesc")
        if not title_div:
            continue
        code_tag = title_div.find("strong", class_="cb_code")
        title_tag = title_div.find("em", class_="cb_title")
        code = code_tag.get_text(strip=True).rstrip(":") if code_tag else ""
        title = title_tag.get_text(strip=True).rstrip(".") if title_tag else ""
        credits_text = title_div.get_text(strip=True)
        credits_match = re.search(r"(\d[\d\-]*\s+credits?)", credits_text)
        credits = credits_match.group(1) if credits_match else ""
        desc = desc_div.get_text(" ", strip=True) if desc_div else ""
        parts.append(f"{code}: {title}")
        parts.append(f"Credits: {credits}\n")
        if desc:
            parts.append(f"{desc}\n")
    return "\n".join(parts)


# ── Main handler ──────────────────────────────────────────────────

def lambda_handler(event, context):
    files_uploaded = 0
    errors = []

    # School overview
    try:
        soup = fetch_soup(f"{BASE_URL}/")
        body = extract_overview(soup)
        put_s3("00-school-of-computing-overview.txt",
               build_file_content("Long Nguyen and Kimmy Duong School of Computing — Overview",
                                  f"{BASE_URL}/", body))
        files_uploaded += 1
    except Exception as e:
        errors.append(f"School overview: {e}")

    # Department pages
    for url, slug, name in DEPT_PAGES:
        try:
            soup = fetch_soup(url)
        except Exception as e:
            errors.append(f"{name}: {e}")
            continue

        # Overview
        try:
            overview = extract_overview(soup)
            put_s3(f"dept-{slug}-overview.txt",
                   build_file_content(f"{name} — Overview", url, overview))
            files_uploaded += 1
        except Exception as e:
            errors.append(f"{name} overview: {e}")

        # Faculty
        try:
            faculty = extract_faculty(soup)
            if faculty:
                put_s3(f"faculty/{slug}-faculty.txt",
                       build_file_content(f"{name} — Faculty", url, faculty))
                files_uploaded += 1
        except Exception as e:
            errors.append(f"{name} faculty: {e}")

        # Courses by subject
        try:
            subjects = identify_subjects(soup)
            for subj_code, blocks in subjects.items():
                subj_name = SUBJECT_NAMES.get(subj_code, subj_code)
                content = courses_to_text(blocks)
                put_s3(f"courses/{subj_code.lower()}-courses.txt",
                       build_file_content(f"{subj_name} ({subj_code}) — Course Catalog", url, content))
                files_uploaded += 1
                logger.info(f"  {subj_code}: {len(blocks)} courses")
        except Exception as e:
            errors.append(f"{name} courses: {e}")

    # Program pages
    for url, filename, name in PROGRAM_PAGES:
        try:
            soup = fetch_soup(url)
            body = extract_program(soup)
            put_s3(filename, build_file_content(name, url, body))
            files_uploaded += 1
        except requests.exceptions.HTTPError as e:
            if "404" in str(e):
                logger.warning(f"Skipped {name} (404)")
            else:
                errors.append(f"{name}: {e}")
        except Exception as e:
            errors.append(f"{name}: {e}")

    result = {
        "files_uploaded": files_uploaded,
        "errors": errors,
        "bucket": S3_BUCKET,
        "prefix": S3_PREFIX,
    }
    logger.info(f"Done: {files_uploaded} files uploaded, {len(errors)} errors")
    if errors:
        logger.error(f"Errors: {errors}")
    return result
